---
---

<section class="relative overflow-hidden py-28 sm:py-36" aria-labelledby="hero-headline">
  <!-- Rainbow line -->
  <div
    class="absolute top-0 left-0 right-0 h-[3px] opacity-80"
    style="background: linear-gradient(90deg, #ff3d00 0%, #ff9100 16.67%, #ffd600 33.33%, #00e676 50%, #448aff 66.67%, #b24bf3 83.33%, #ff2d95 100%);"
    aria-hidden="true"
  ></div>

  <!-- Radial glow backgrounds -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div
      class="absolute -top-1/5 left-1/2 -translate-x-1/2 w-[900px] h-[600px] rounded-full"
      style="background: radial-gradient(ellipse at center, rgba(6,214,224,0.08) 0%, rgba(178,75,243,0.06) 40%, transparent 70%);"
    ></div>
    <div
      class="absolute -bottom-1/10 -right-1/10 w-[500px] h-[500px]"
      style="background: radial-gradient(ellipse at center, rgba(255,45,149,0.06) 0%, transparent 70%);"
    ></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 mx-auto max-w-[820px] px-6 text-center">
    <!-- Eyebrow -->
    <p
      class="mb-7 inline-flex items-center gap-2 font-mono text-[0.75rem] font-medium uppercase tracking-[0.18em] text-brand-electric"
      style="opacity: 0; animation: fadeUp 0.6s ease 0.1s forwards;"
      aria-hidden="true"
    >
      <span class="opacity-40">—</span>
      Privacy-first security infrastructure
      <span class="opacity-40">—</span>
    </p>

    <!-- Headline -->
    <h1
      class="mb-6 font-heading font-bold leading-[1.1] tracking-[-0.01em] text-text-primary"
      style="font-size: clamp(2.4rem, 5vw, 3.8rem); opacity: 0; animation: fadeUp 0.6s ease 0.2s forwards;"
      id="hero-headline"
    >
      Cybersecurity for the organizations that&nbsp;<em class="not-italic text-brand-electric">protect our communities.</em>
    </h1>

    <!-- Sub -->
    <p
      class="mx-auto mb-10 max-w-[600px] text-[1.2rem] leading-[1.65] text-text-secondary"
      style="opacity: 0; animation: fadeUp 0.6s ease 0.3s forwards;"
    >
      Secure Pride scans your AI workflows for hidden threats and sensitive data
      leaks—so you can focus on the work that matters.
    </p>

    <!-- Actions -->
    <div
      class="mb-5 flex flex-wrap items-center justify-center gap-4"
      style="opacity: 0; animation: fadeUp 0.6s ease 0.4s forwards;"
    >
      <a
        href="#get-involved"
        class="inline-flex items-center gap-2 font-heading font-bold text-base uppercase tracking-[0.06em] rounded-full bg-brand-electric text-dark-void px-7 py-[0.85rem] min-h-[44px] transition-all duration-250 hover:bg-neon-cyan hover:-translate-y-0.5 hover:shadow-glow focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-electric"
      >
        Get protected
      </a>
      <a
        href="#what-we-do"
        class="inline-flex items-center gap-2 font-heading font-bold text-base uppercase tracking-[0.06em] rounded-full border border-dark-borderGlow text-text-primary px-7 py-[0.85rem] min-h-[44px] transition-all duration-250 hover:border-brand-electric hover:text-brand-electric hover:-translate-y-0.5 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-electric"
      >
        See how it works
      </a>
    </div>

    <!-- Support text -->
    <p
      class="text-[0.85rem] text-text-muted"
      style="opacity: 0; animation: fadeUp 0.6s ease 0.5s forwards;"
    >
      Free for organizations with fewer than 10 staff. No credit card required.
    </p>
  </div>
</section>

<!-- Trust Bar -->
<div class="bg-dark-surface border-y border-dark-border py-5" aria-label="Trust indicators">
  <div class="mx-auto max-w-[900px] px-6 flex flex-wrap items-center justify-center gap-3 font-mono text-[0.8rem] font-medium tracking-[0.06em] text-text-secondary">
    <span class="flex items-center gap-[0.4rem]">
      <span class="w-[6px] h-[6px] rounded-full bg-brand-electric flex-shrink-0" aria-hidden="true"></span>
      Built by LGBTQ+ technologists
    </span>
    <span class="text-dark-borderGlow" aria-hidden="true">/</span>
    <span class="flex items-center gap-[0.4rem]">
      <span class="w-[6px] h-[6px] rounded-full bg-brand-electric flex-shrink-0" aria-hidden="true"></span>
      Open source
    </span>
    <span class="text-dark-borderGlow" aria-hidden="true">/</span>
    <span class="flex items-center gap-[0.4rem]">
      <span class="w-[6px] h-[6px] rounded-full bg-brand-electric flex-shrink-0" aria-hidden="true"></span>
      Self-hostable
    </span>
    <span class="text-dark-borderGlow" aria-hidden="true">/</span>
    <span class="flex items-center gap-[0.4rem]">
      <span class="w-[6px] h-[6px] rounded-full bg-brand-electric flex-shrink-0" aria-hidden="true"></span>
      Your data never leaves your infrastructure
    </span>
  </div>
</div>
