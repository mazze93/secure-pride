---

<header class="sticky top-0 z-50 border-b border-dark-border bg-dark-bg/88 backdrop-blur-md">
  <nav
    class="mx-auto flex max-w-[1120px] items-center justify-between px-6 h-16"
    aria-label="Main navigation"
  >
    <!-- Wordmark -->
    <a
      href="/"
      class="font-display text-[1.1rem] font-bold uppercase tracking-[0.12em] text-brand-electric transition-colors duration-250 hover:opacity-80 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-electric"
      aria-label="Secure Pride home"
    >
      Secure<span class="text-brand-hotPink">&nbsp;Pride</span>
    </a>

    <!-- Navigation Links -->
    <ul class="hidden md:flex items-center gap-8 list-none" role="list">
      <li>
        <a
          href="#what-we-do"
          class="font-heading text-[0.95rem] font-semibold uppercase tracking-[0.05em] text-text-secondary transition-colors duration-250 hover:text-brand-electric focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-electric rounded-sm"
        >
          Product
        </a>
      </li>
      <li>
        <a
          href="#pricing"
          class="font-heading text-[0.95rem] font-semibold uppercase tracking-[0.05em] text-text-secondary transition-colors duration-250 hover:text-brand-electric focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-electric rounded-sm"
        >
          Pricing
        </a>
      </li>
      <li>
        <a
          href="#about"
          class="font-heading text-[0.95rem] font-semibold uppercase tracking-[0.05em] text-text-secondary transition-colors duration-250 hover:text-brand-electric focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-electric rounded-sm"
        >
          About
        </a>
      </li>
      <li>
        <a
          href="https://github.com/mazze93/Secure-Pride"
          target="_blank"
          rel="noopener noreferrer"
          class="font-heading text-[0.95rem] font-semibold uppercase tracking-[0.05em] text-text-secondary transition-colors duration-250 hover:text-brand-electric focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-electric rounded-sm"
        >
          GitHub
        </a>
      </li>
      <li>
        <a
          href="#get-involved"
          class="font-heading text-[0.9rem] font-bold uppercase tracking-[0.08em] rounded-full bg-brand-electric px-[1.1rem] py-[0.45rem] text-dark-void transition-all duration-250 hover:bg-neon-cyan hover:-translate-y-px focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-electric"
        >
          Get protected
        </a>
      </li>
    </ul>
  </nav>
</header>
