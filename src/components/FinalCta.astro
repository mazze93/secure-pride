---
---

<section
  class="relative z-10 overflow-hidden py-28 text-center"
  aria-labelledby="final-cta-headline"
>
  <!-- Dual radial glows -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse at 30% 50%, rgba(6,214,224,0.06) 0%, transparent 60%), radial-gradient(ellipse at 70% 50%, rgba(255,45,149,0.05) 0%, transparent 60%);"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 mx-auto max-w-[680px] px-6">
    <h2
      class="reveal font-heading font-bold leading-[1.2] text-text-primary mb-10"
      style="font-size: clamp(1.9rem, 4vw, 2.8rem);"
      id="final-cta-headline"
    >
      Your community is doing important work. Let's make sure it stays protected.
    </h2>

    <div class="reveal reveal-delay-1">
      <a
        href="#get-involved"
        class="inline-flex items-center justify-center rounded-full bg-brand-electric font-heading font-bold uppercase tracking-[0.06em] text-dark-void transition-all duration-250 hover:bg-neon-cyan hover:-translate-y-0.5 hover:shadow-glow focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-electric"
        style="font-size: 1.05rem; padding: 1rem 2.25rem;"
      >
        Get protected
      </a>
    </div>

    <p class="reveal reveal-delay-2 mt-4 text-[0.85rem] text-text-muted">
      Free for organizations with fewer than 10 staff. Open source. Self-hostable.
    </p>
  </div>
</section>
