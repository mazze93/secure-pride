---
---

<section
  id="about"
  class="relative z-10 py-24 overflow-hidden"
  style="background: linear-gradient(180deg, #0a0a1a 0%, #0d0d1f 100%);"
  aria-labelledby="about-headline"
>
  <!-- Radial glow -->
  <div
    class="absolute -bottom-1/5 left-1/2 -translate-x-1/2 w-[800px] h-[400px] pointer-events-none"
    style="background: radial-gradient(ellipse, rgba(178,75,243,0.06) 0%, transparent 70%);"
    aria-hidden="true"
  ></div>

  <div class="relative mx-auto max-w-[1120px] px-6">
    <div class="grid gap-20 md:grid-cols-2 md:items-center">

      <!-- Left: text -->
      <div>
        <p class="reveal mb-4 font-mono text-[0.72rem] font-medium uppercase tracking-[0.2em] text-brand-electric opacity-80">
          About
        </p>
        <h2 class="reveal reveal-delay-1 font-heading text-[clamp(1.8rem,3.5vw,2.75rem)] font-bold leading-[1.15] text-text-primary" id="about-headline">
          Built by the community, for the community.
        </h2>
        <div class="mt-5 flex flex-col gap-5">
          <p class="reveal reveal-delay-2 text-[1.05rem] leading-[1.75] text-text-secondary">
            Secure Pride is an open-source cybersecurity project built by
            LGBTQ+ technologists who got tired of watching our organizations
            struggle with tools designed for someone else.
          </p>
          <p class="reveal reveal-delay-2 text-[1.05rem] leading-[1.75] text-text-secondary">
            We believe security infrastructure should be as thoughtfully
            designed as the communities it protects. That means tools that
            speak plainly, respect your time, look like they belong to you,
            and never treat your data as a product.
          </p>
          <p class="reveal reveal-delay-3 text-[0.95rem] text-text-muted">
            Our scanner is Apache 2.0 licensed. Our code is auditable. Our
            roadmap is public. If you want to contribute,{' '}
            <a
              href="https://github.com/secure-pride"
              target="_blank"
              rel="noopener noreferrer"
              class="text-brand-electric underline underline-offset-[3px] transition-colors duration-250 hover:text-neon-cyan"
            >
              the door is open.
            </a>
          </p>
        </div>
      </div>

      <!-- Right: badges -->
      <div class="reveal reveal-delay-2 flex flex-col gap-4" aria-label="Key commitments">
        <div class="flex items-center gap-4 rounded-xl border border-dark-border bg-dark-elevated px-5 py-[1.1rem] transition-colors duration-200 hover:border-dark-borderGlow">
          <span class="w-9 flex-shrink-0 text-center text-[1.4rem]" aria-hidden="true">🔓</span>
          <div>
            <strong class="block font-heading text-[0.9rem] font-bold text-text-primary mb-[0.15rem]">Apache 2.0 licensed</strong>
            <span class="text-[0.82rem] text-text-muted leading-[1.4]">Our scanner is open source. Inspect it, fork it, deploy it.</span>
          </div>
        </div>

        <div class="flex items-center gap-4 rounded-xl border border-dark-border bg-dark-elevated px-5 py-[1.1rem] transition-colors duration-200 hover:border-dark-borderGlow">
          <span class="w-9 flex-shrink-0 text-center text-[1.4rem]" aria-hidden="true">🏗</span>
          <div>
            <strong class="block font-heading text-[0.9rem] font-bold text-text-primary mb-[0.15rem]">Self-hostable</strong>
            <span class="text-[0.82rem] text-text-muted leading-[1.4]">Your data stays on your infrastructure. Always.</span>
          </div>
        </div>

        <div class="flex items-center gap-4 rounded-xl border border-dark-border bg-dark-elevated px-5 py-[1.1rem] transition-colors duration-200 hover:border-dark-borderGlow">
          <span class="w-9 flex-shrink-0 text-center text-[1.4rem]" aria-hidden="true">🗺</span>
          <div>
            <strong class="block font-heading text-[0.9rem] font-bold text-text-primary mb-[0.15rem]">Public roadmap</strong>
            <span class="text-[0.82rem] text-text-muted leading-[1.4]">Development priorities come from community feedback.</span>
          </div>
        </div>

        <div class="flex items-center gap-4 rounded-xl border border-dark-border bg-dark-elevated px-5 py-[1.1rem] transition-colors duration-200 hover:border-dark-borderGlow">
          <span class="w-9 flex-shrink-0 text-center text-[1.4rem]" aria-hidden="true">🤝</span>
          <div>
            <strong class="block font-heading text-[0.9rem] font-bold text-text-primary mb-[0.15rem]">Works alongside other tools</strong>
            <span class="text-[0.82rem] text-text-muted leading-[1.4]">Secure Pride protects your AI workflows. For endpoint and network security, we recommend pairing with Defender or CrowdStrike.</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
