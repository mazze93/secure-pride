---
---

<footer class="relative z-10 border-t border-dark-border bg-dark-void py-16 pt-8" aria-label="Site footer">
  <div class="mx-auto max-w-[1120px] px-6">

    <!-- Rainbow line -->
    <div
      class="mb-12 h-[2px] rounded-px opacity-40"
      style="background: linear-gradient(90deg, #ff3d00 0%, #ff9100 16.67%, #ffd600 33.33%, #00e676 50%, #448aff 66.67%, #b24bf3 83.33%, #ff2d95 100%);"
      aria-hidden="true"
    ></div>

    <!-- Columns -->
    <div class="mb-12 pb-12 border-b border-dark-border grid gap-10 sm:grid-cols-2 lg:grid-cols-[2fr_1fr_1fr_1fr_1fr]">

      <!-- Brand -->
      <div>
        <a
          href="/"
          class="mb-3 block font-display text-[1.1rem] font-bold uppercase tracking-[0.12em] text-brand-electric transition-opacity duration-150 hover:opacity-80 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-electric"
          aria-label="Secure Pride home"
        >
          Secure<span class="text-brand-hotPink">&nbsp;Pride</span>
        </a>
        <p class="text-[0.85rem] leading-[1.5] text-text-muted">
          Cybersecurity for LGBTQ+ organizations.
        </p>
      </div>

      <!-- Product -->
      <div>
        <p class="mb-4 font-heading text-[0.8rem] font-bold uppercase tracking-[0.12em] text-text-secondary">
          Product
        </p>
        <ul class="flex flex-col gap-2 list-none" role="list">
          <li><a href="#" class="text-[0.85rem] text-text-muted transition-colors duration-150 hover:text-brand-electric focus-visible:outline-neon-cyan">Scanner</a></li>
          <li><a href="#" class="text-[0.85rem] text-text-muted transition-colors duration-150 hover:text-brand-electric focus-visible:outline-neon-cyan">Dashboard</a></li>
          <li>
            <a
              href="https://docs.securepride.org"
              target="_blank"
              rel="noopener noreferrer"
              class="text-[0.85rem] text-text-muted transition-colors duration-150 hover:text-brand-electric focus-visible:outline-neon-cyan"
            >
              Docs
            </a>
          </li>
          <li><a href="/security" class="text-[0.85rem] text-text-muted transition-colors duration-150 hover:text-brand-electric focus-visible:outline-neon-cyan">Security policy</a></li>
        </ul>
      </div>

      <!-- Community -->
      <div>
        <p class="mb-4 font-heading text-[0.8rem] font-bold uppercase tracking-[0.12em] text-text-secondary">
          Community
        </p>
        <ul class="flex flex-col gap-2 list-none" role="list">
          <li>
            <a
              href="https://github.com/securepride"
              target="_blank"
              rel="noopener noreferrer"
              class="text-[0.85rem] text-text-muted transition-colors duration-150 hover:text-brand-electric focus-visible:outline-neon-cyan"
            >
              GitHub
            </a>
          </li>
          <li><a href="#" class="text-[0.85rem] text-text-muted transition-colors duration-150 hover:text-brand-electric focus-visible:outline-neon-cyan">Contributing</a></li>
          <li><a href="#" class="text-[0.85rem] text-text-muted transition-colors duration-150 hover:text-brand-electric focus-visible:outline-neon-cyan">Code of conduct</a></li>
        </ul>
      </div>

      <!-- Organization -->
      <div>
        <p class="mb-4 font-heading text-[0.8rem] font-bold uppercase tracking-[0.12em] text-text-secondary">
          Organization
        </p>
        <ul class="flex flex-col gap-2 list-none" role="list">
          <li><a href="#about" class="text-[0.85rem] text-text-muted transition-colors duration-150 hover:text-brand-electric focus-visible:outline-neon-cyan">About</a></li>
          <li><a href="/privacy" class="text-[0.85rem] text-text-muted transition-colors duration-150 hover:text-brand-electric focus-visible:outline-neon-cyan">Privacy policy</a></li>
          <li><a href="#get-involved" class="text-[0.85rem] text-text-muted transition-colors duration-150 hover:text-brand-electric focus-visible:outline-neon-cyan">Contact</a></li>
        </ul>
      </div>

      <!-- Support -->
      <div>
        <p class="mb-4 font-heading text-[0.8rem] font-bold uppercase tracking-[0.12em] text-text-secondary">
          Support
        </p>
        <ul class="flex flex-col gap-2 list-none" role="list">
          <li>
            <a
              href="https://docs.securepride.org"
              target="_blank"
              rel="noopener noreferrer"
              class="text-[0.85rem] text-text-muted transition-colors duration-150 hover:text-brand-electric focus-visible:outline-neon-cyan"
            >
              Documentation
            </a>
          </li>
          <li><a href="#get-involved" class="text-[0.85rem] text-text-muted transition-colors duration-150 hover:text-brand-electric focus-visible:outline-neon-cyan">Get help</a></li>
          <li><a href="/security" class="text-[0.85rem] text-text-muted transition-colors duration-150 hover:text-brand-electric focus-visible:outline-neon-cyan">Report a vulnerability</a></li>
        </ul>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="flex flex-wrap items-center justify-between gap-4">
      <p class="font-mono text-[0.75rem] text-text-muted">
        © 2026 Secure Pride. Apache 2.0 License. Built with pride.
      </p>
      <p class="font-mono text-[0.75rem] text-text-muted">
        <a
          href="https://mazzeleczzare.com"
          target="_blank"
          rel="noopener noreferrer"
          class="text-text-muted transition-colors duration-150 hover:text-brand-electric focus-visible:outline-neon-cyan"
        >
          mazzeleczzare.com
        </a>
      </p>
    </div>

  </div>
</footer>
