---
---

<section
  id="pricing"
  class="relative z-10 py-24 bg-dark-surface"
  aria-labelledby="pricing-headline"
>
  <div class="mx-auto max-w-[1120px] px-6">
    <header class="mb-16 max-w-[600px]">
      <p class="reveal mb-4 font-mono text-[0.72rem] font-medium uppercase tracking-[0.2em] text-brand-electric opacity-80">
        Pricing
      </p>
      <h2 class="reveal reveal-delay-1 font-heading text-[clamp(1.8rem,3.5vw,2.75rem)] font-bold leading-[1.15] text-text-primary" id="pricing-headline">
        Security shouldn't require a fundraising campaign.
      </h2>
      <p class="reveal reveal-delay-2 mt-5 text-[1.1rem] leading-[1.7] text-text-secondary max-w-[600px]">
        Secure Pride is free for small organizations and priced for sustainability,
        not extraction.
      </p>
    </header>

    <div class="grid gap-6 md:grid-cols-3 items-start">

      <!-- Community — Featured -->
      <article
        class="relative rounded-xl border bg-dark-elevated p-8 reveal"
        style="border-color: #06d6e0; box-shadow: 0 0 40px rgba(6,214,224,0.08);"
        aria-labelledby="community-tier-label"
      >
        <!-- Floating badge -->
        <div class="absolute -top-3.5 left-1/2 -translate-x-1/2 whitespace-nowrap rounded-full bg-brand-electric px-3 py-1 font-mono text-[0.65rem] font-bold uppercase tracking-[0.1em] text-dark-void">
          Most organizations start here
        </div>

        <p class="mb-3 font-mono text-[0.7rem] uppercase tracking-[0.18em] text-text-muted" id="community-tier-label">
          Community
        </p>
        <p class="font-heading text-[2.5rem] font-bold leading-none text-text-primary mb-1">Free</p>
        <p class="mb-6 text-[0.85rem] text-text-muted">Organizations with fewer than 10 staff</p>
        <div class="mb-4 h-px bg-dark-border"></div>
        <p class="mb-3 text-[0.95rem] leading-[1.65] text-text-secondary">
          Full scanner. Full dashboard. No feature gates. No credit card.
        </p>
        <p class="font-heading text-[0.95rem] font-bold text-neon-green">
          This isn't a trial. This is the product.
        </p>
        <div class="mt-6">
          <a
            href="#get-involved"
            class="flex w-full items-center justify-center rounded-full bg-brand-electric py-[0.85rem] font-heading font-bold uppercase tracking-[0.06em] text-dark-void transition-all duration-250 hover:bg-neon-cyan hover:-translate-y-0.5 hover:shadow-glow focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-electric"
          >
            Get protected
          </a>
        </div>
      </article>

      <!-- Organization -->
      <article
        class="rounded-xl border border-dark-border bg-dark-elevated p-8 reveal reveal-delay-1"
        aria-labelledby="org-tier-label"
      >
        <p class="mb-3 font-mono text-[0.7rem] uppercase tracking-[0.18em] text-text-muted" id="org-tier-label">
          Organization
        </p>
        <p class="font-heading font-bold leading-none text-text-primary mb-1" style="font-size: 2.5rem;">
          $200<sub class="text-base font-normal text-text-muted" style="vertical-align: baseline;">/month</sub>
        </p>
        <p class="mb-6 text-[0.85rem] text-text-muted">Teams of 10–50</p>
        <div class="mb-4 h-px bg-dark-border"></div>
        <p class="mb-3 text-[0.95rem] leading-[1.65] text-text-secondary">
          Everything in Community, plus priority support, custom policy templates,
          and audit log exports.
        </p>
        <p class="font-heading text-[0.9rem] font-semibold italic text-brand-electric">
          Less than the cost of one incident response consultation.
        </p>
        <div class="mt-6">
          <a
            href="#get-involved"
            class="flex w-full items-center justify-center rounded-full border border-dark-borderGlow py-[0.85rem] font-heading font-bold uppercase tracking-[0.06em] text-text-primary transition-all duration-250 hover:border-brand-electric hover:text-brand-electric hover:-translate-y-0.5 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-electric"
          >
            Get started
          </a>
        </div>
      </article>

      <!-- Coalition -->
      <article
        class="rounded-xl border border-dark-border bg-dark-elevated p-8 reveal reveal-delay-2"
        aria-labelledby="coalition-tier-label"
      >
        <p class="mb-3 font-mono text-[0.7rem] uppercase tracking-[0.18em] text-text-muted" id="coalition-tier-label">
          Coalition
        </p>
        <p class="font-heading font-bold leading-none text-text-primary mb-1" style="font-size: 1.75rem;">
          Custom
        </p>
        <p class="mb-6 text-[0.85rem] text-text-muted">Networks, umbrella groups, fiscal sponsors</p>
        <div class="mb-4 h-px bg-dark-border"></div>
        <p class="mb-3 text-[0.95rem] leading-[1.65] text-text-secondary">
          For managing security across multiple organizations simultaneously.
        </p>
        <p class="font-heading text-[0.9rem] font-semibold italic text-brand-electric">
          Talk to us. We'll build something that works.
        </p>
        <div class="mt-6">
          <a
            href="mailto:hello@securepride.org"
            class="flex w-full items-center justify-center rounded-full border border-dark-borderGlow py-[0.85rem] font-heading font-bold uppercase tracking-[0.06em] text-text-primary transition-all duration-250 hover:border-brand-electric hover:text-brand-electric hover:-translate-y-0.5 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-electric"
          >
            Get in touch
          </a>
        </div>
      </article>

    </div>
  </div>
</section>
